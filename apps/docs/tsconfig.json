{
    "extends": "tsconfig",
    "compilerOptions": {
        "target": "ES2017",
        "allowJs": true,
        "strict": false,
        "incremental": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "noUncheckedSideEffectImports": false,
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "next-env.d.ts",
        "dist/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
